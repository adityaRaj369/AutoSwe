# ---------- GitHub ----------
# Option A: full GitHub App (production). Provide App ID + private key path.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./github-private-key.pem
GITHUB_WEBHOOK_SECRET=
# Option B: Personal Access Token (quick local testing). If set, used directly.
GITHUB_PAT=
GITHUB_DEFAULT_BASE_BRANCH=main

# ---------- Jira ----------
# Create a Jira automation/webhook that calls:
# POST http://YOUR_HOST/api/webhook/jira?secret=YOUR_SECRET
# when an issue transitions to the configured status.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=
JIRA_AUTO_STATUS=AutoSWE,In Progress,To Do
# Comma-separated mapping: PROJECTKEY=githubOwner/repoName
JIRA_PROJECT_REPO_MAP=

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://autoswe:autoswe@localhost:5432/autoswe

# ---------- Redis / Queue ----------
REDIS_URL=redis://localhost:6379
WORKER_MAX_JOBS=2
WORKER_JOB_TIMEOUT_S=900

# ---------- Agent LLM ----------
# Production recommendation: use an OpenAI-compatible hosted model.
# A 70B-class model is needed to reliably drive the ReAct/JSON agent loop;
# smaller models (7B/8B) tend to fail the action protocol mid-run.
# GroqCloud example (LLM_API_KEY may be a comma-separated list of keys to rotate):
LLM_PROVIDER=openai-compatible
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_TIMEOUT_S=45
LLM_MAX_RETRIES=2
LLM_REQUESTS_PER_MINUTE=10

# ---------- LLM fallback chain ----------
# When the primary provider is rate-limited (HTTP 429), the agent automatically
# falls through to these free providers in order. Leave a key blank to skip it.
LLM_FALLBACK_ENABLED=true
# Keep race mode off for free API tiers. Racing calls every provider per step
# and quickly causes 429s. Use sequential fallback for stable demo runs.
LLM_RACE_ENABLED=false
LLM_FALLBACK_ORDER=groq,primary,openrouter,ollama
LLM_LOCAL_FALLBACK_ENABLED=true
# Google Gemini — free key at https://aistudio.google.com/apikey (~1500 req/day, no card)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_REQUESTS_PER_MINUTE=10
# Groq — fast free tier, but often lower token limits than Gemini/OpenRouter
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_REQUESTS_PER_MINUTE=20
# OpenRouter — free models at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REQUESTS_PER_MINUTE=10

# ---------- Ollama ----------
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=deepseek-coder-v2:16b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_CONCURRENCY=1
OLLAMA_TIMEOUT_S=60

# ---------- ChromaDB ----------
CHROMA_URL=http://localhost:8000

# ---------- Server ----------
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# ---------- Agent ----------
AGENT_MAX_STEPS=15
AGENT_STEP_TIMEOUT_MS=120000
AGENT_MAX_CONTEXT_TOKENS=8000
AGENT_FULL_TRAJECTORY_STEPS=10

# ---------- Sandbox ----------
SANDBOX_IMAGE=autoswe-sandbox:latest
SANDBOX_MEMORY_MB=2048
SANDBOX_CPU_CORES=1
SANDBOX_WORKDIR=/workspace
# Set to true to run agent commands on the host (no Docker daemon required).
SANDBOX_USE_LOCAL=false

# ---------- Dashboard (Vite) ----------
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
